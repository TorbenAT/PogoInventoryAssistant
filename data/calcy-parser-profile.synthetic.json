    { "field": "FastMove", "pattern": "(?:^|\\s)fast=(?<value>[^;\\r\\n]+?)(?=\\s+[a-zA-Z0-9_]+=|;|$)", "sourceName": "logcat" },
    { "field": "ChargedMove1", "pattern": "(?:^|\\s)charge1=(?<value>[^;\\r\\n]+?)(?=\\s+[a-zA-Z0-9_]+=|;|$)", "sourceName": "logcat" },
    { "field": "ChargedMove2", "pattern": "(?:^|\\s)charge2=(?<value>[^;\\r\\n]+?)(?=\\s+[a-zA-Z0-9_]+=|;|$)", "sourceName": "logcat" }
